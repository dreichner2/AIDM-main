# AIDM hosted closed-beta environment template.
# Copy to the deployment provider's secret/env manager; do not deploy this file
# with placeholder values.
# Validate the filled target with:
# make deployment-readiness DEPLOYMENT_READINESS_ARGS="--env-file /path/to/env --target-url https://aidm.example.com --auth-token <token>"

AIDM_ENV=production
AIDM_DEBUG=false
AIDM_AUTO_CREATE_SCHEMA=false
AIDM_SERVE_FRONTEND=true
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# Database and migrations.
AIDM_DATABASE_URI=postgresql+psycopg://aidm:replace-password@db.example.internal:5432/aidm

# REST and Socket.IO exposure.
AIDM_AUTH_REQUIRED=true
AIDM_API_AUTH_TOKENS=replace-bootstrap-or-operator-token
AIDM_CORS_ALLOWLIST=https://aidm.example.com
AIDM_SOCKET_CORS_ALLOWLIST=https://aidm.example.com
AIDM_TRUSTED_PROXY_COUNT=1

# Production stores.
AIDM_RATE_LIMIT_STORE=database
AIDM_TURN_COORDINATOR_STORE=database
AIDM_TURN_COORDINATOR_LOCK_TTL_SECONDS=900
AIDM_TURN_COORDINATOR_POLL_INTERVAL_MS=50

# Socket.IO worker model. Use one of:
# - single: exactly one backend worker
# - sticky: multiple workers with load balancer affinity
# - message_queue: multiple workers with a shared Socket.IO message queue
AIDM_SOCKETIO_ASYNC_MODE=threading
AIDM_SOCKETIO_WORKER_MODEL=single
# AIDM_SOCKETIO_MESSAGE_QUEUE=redis://redis.example.internal:6379/0

# Hosted observability ownership.
AIDM_OBSERVABILITY_PROVIDER=replace-with-provider-name
AIDM_ALERT_OWNER=replace-with-team-or-person
AIDM_TELEMETRY_ENABLED=true
AIDM_TELEMETRY_ENDPOINT=https://telemetry.example.com/ingest
AIDM_TELEMETRY_API_KEY=replace-with-telemetry-token

# Response hardening headers.
AIDM_SECURITY_HEADERS_ENABLED=true
# Override only if your hosting layer supplies an equivalent CSP.
# AIDM_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss:; media-src 'self' data: blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Hosted same-origin cookie auth. Keep token responses enabled only if API
# clients still need raw account tokens.
AIDM_ACCOUNT_COOKIE_AUTH_ENABLED=true
AIDM_ACCOUNT_COOKIE_SECURE=true
AIDM_ACCOUNT_COOKIE_SAMESITE=Lax
AIDM_ACCOUNT_TOKEN_RESPONSE_ENABLED=false

# LLM provider.
AIDM_LLM_PROVIDER=gemini
AIDM_LLM_MODEL=models/gemini-3-flash-preview
GOOGLE_GENAI_API_KEY=replace-with-provider-key

# Optional TTS.
# AIDM_DEEPGRAM_API_KEY=replace-with-deepgram-key
# AIDM_DEEPGRAM_TTS_MODEL=aura-2-draco-en
